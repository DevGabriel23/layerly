---
// src/pages/editor/[id].astro
import Layout from "../../layouts/Layout.astro";
import LayerCard from "../../components/editor/LayerCard.astro";
import { createSupabaseSSR } from "../../lib/supabase";
import ColorPicker from "../../components/editor/ColorPicker.astro";
import Modal from "../../components/ui/Modal.astro";

const { id } = Astro.params;
const { searchParams } = Astro.url;

const user = Astro.locals.user;
const token = Astro.locals.token;

const supabase = createSupabaseSSR(Astro);

const isPublicView = searchParams.get("view") === "public";

const { data: project } = await supabase
	.from("avatar_config")
	.select("*")
	.eq("id", id as string)
	.maybeSingle();
if (!project) return Astro.redirect("/dashboard?error=not_found");

const isOwner = user?.id === project.user_id;

if (!isPublicView && !isOwner) {
	return Astro.redirect("/dashboard?error=unauthorized");
}

const { data: layers } = await supabase
	.from("layers")
	.select("*, variants(*)")
	.eq("project_id", id as string)
	.order("z_order", { ascending: false });

const sortedLayers = layers || [];

const canEditLayers = isOwner && !isPublicView;
console.log("canEditLayers", canEditLayers);
---

<Layout title={`Editor: ${project.project_name}`}>
	<main
		id="editor-root"
		data-project-id={id}
		class="w-full max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8 p-0 sm:p-8 sm:min-h-screen"
	>
		<!-- TODO: Mobile VERSION -->
		<div
			class="lg:hidden fixed inset-0 z-150 flex flex-col items-center justify-center p-6 text-center backdrop-blur-xl bg-bg/80"
		>
			<span class="text-4xl mb-4 animate-bounce">🚧</span>

			<h3
				class="text-2xl font-black text-heading italic uppercase tracking-tighter mb-2"
			>
				Jardín en Mantenimiento
			</h3>

			<p
				class="text-sm font-bold text-muted italic max-w-[250px] leading-relaxed"
			>
				Estamos preparando la versión móvil para que sea mágica. ¡Vuelve
				pronto! ✨
			</p>

			<div
				class="mt-8 px-6 py-2 border-2 border-dashed border-border rounded-full text-[10px] font-black text-primary uppercase tracking-widest"
			>
				Coming Soon
			</div>
		</div>
		<!-- Left Side -->
		<div
			class="lg:col-span-5 sticky top-0 z-40 bg-bg/80 backdrop-blur-md lg:static lg:bg-transparent p-4 lg:p-0"
		>
			<!-- Back Button and Title -->
			<div class="flex w-full lg:hidden items-center gap-4 mb-6">
				<a
					href="/dashboard"
					class="w-11 h-11 flex items-center justify-center rounded-full bg-bg border-2 border-border/40 text-muted hover:text-primary hover:border-primary transition-all"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="20"
						height="20"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="3"
						stroke-linecap="round"
						stroke-linejoin="round"
						><path d="m15 18-6-6 6-6"></path></svg
					>
				</a>

				<h2
					class="text-2xl font-black text-heading italic uppercase tracking-tighter"
				>
					Capas del Diseño
				</h2>
			</div>

			<!-- Canvas -->
			<div
				class="relative aspect-square bg-white border-[6px] border-border rounded-[2.5rem] lg:rounded-[3rem] overflow-hidden shadow-xl lg:shadow-[0_20px_50px_rgba(93,64,55,0.1)] transition-all duration-500"
			>
				<div
					id="canvas-container"
					class="w-full h-full relative flex items-center justify-center bg-bg"
				>
					<p
						id="canvas-placeholder"
						class="text-slate-500 font-black uppercase tracking-[0.2em] text-[10px] animate-pulse italic"
					>
						Selecciona variantes
					</p>
				</div>
			</div>

			<!-- Desktop Export Button -->
			<div class="hidden lg:block cottage-card p-8 mt-6">
				<p
					class="text-[10px] font-black text-primary uppercase tracking-[0.3em] mb-2"
				>
					Proyecto Activo
				</p>
				<h1
					class="text-3xl font-black text-heading italic uppercase tracking-tighter mb-6"
				>
					{project.project_name}
				</h1>
				<button
					id="export-btn-desktop"
					disabled
					class="cottage-btn-primary w-full py-5"
					>Exportar PNG ✨</button
				>
			</div>
		</div>

		<!-- Right Side -->
		<div
			class="lg:col-span-7 flex flex-col h-screen lg:h-[calc(100vh-4rem)] sticky top-20"
		>
			<header
				class="flex flex-col lg:flex-row items-center justify-between border-b-4 border-border/20 pb-6 mb-6"
			>
				<!-- Back Button and Title -->
				<div class="flex w-full lg:w-auto items-center gap-4">
					{
						canEditLayers && (
							<a
								href="/dashboard"
								class="w-11 h-11 flex items-center justify-center rounded-full bg-bg border-2 border-border/40 text-muted hover:text-primary hover:border-primary transition-all"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="20"
									height="20"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="3"
									stroke-linecap="round"
									stroke-linejoin="round"
								>
									<path d="m15 18-6-6 6-6" />
								</svg>
							</a>
						)
					}
					<h2
						class="text-2xl font-black text-heading italic uppercase tracking-tighter"
					>
						Capas del Diseño
					</h2>
				</div>

				<!-- New Layer Button Desktop -->
				{
					canEditLayers && (
						<button
							id="open-modal-btn"
							class="cottage-btn-primary text-sm! hidden lg:block"
						>
							+ Nueva Capa
						</button>
					)
				}
			</header>
			<!-- Layers List Desktop -->
			<div
				id="layers-list"
				class="flex-1 overflow-y-auto pr-2 custom-scrollbar space-y-6 pb-32"
			>
				{
					sortedLayers.length > 0 ? (
						sortedLayers.map((layer) => (
							<LayerCard
								layer={layer}
								readonly={!canEditLayers}
							/>
						))
					) : (
						<div
							id="empty-layers-state"
							class="flex flex-col items-center justify-center py-20 px-6 text-center"
						>
							<div class="relative mb-8">
								<div class="w-20 h-20 bg-bg border-4 border-dashed border-border/40 rounded-4xl flex items-center justify-center animate-pulse">
									<span class="text-3xl opacity-40">🌱</span>
								</div>
								<div class="absolute -top-2 -right-2 w-6 h-6 bg-primary/20 rounded-full animate-ping" />
							</div>

							<h3 class="text-xl font-black text-heading italic uppercase tracking-tighter mb-2">
								Tu jardín está vacío
							</h3>
							<p class="text-xs text-muted font-bold max-w-[200px] leading-relaxed italic">
								Siembra tu primera capa para empezar a crear
								magia.
							</p>

							<div class="w-full mt-12 space-y-4 opacity-30 pointer-events-none">
								<div class="h-24 w-full bg-bg border-2 border-border/20 rounded-4xl animate-pulse" />
								<div class="h-24 w-[90%] mx-auto bg-bg border-2 border-border/10 rounded-4xl animate-pulse" />
							</div>
						</div>
					)
				}
			</div>
		</div>

		<div
			id="layers-sheet"
			class="fixed lg:hidden inset-x-0 bottom-0 z-50 bg-white border-t-[6px] border-border rounded-t-[3rem] shadow-[0_-20px_50px_rgba(93,64,55,0.15)] transition-transform duration-500 translate-y-[calc(100%-60px)] lg:relative lg:translate-y-0 lg:border-t-0 lg:shadow-none lg:bg-transparent h-[70vh] lg:h-full flex flex-col"
		>
			<div
				class="flex justify-center p-4 cursor-pointer"
				id="sheet-handle"
			>
				<div class="w-12 h-1.5 bg-border/60 rounded-full"></div>
			</div>

			<header
				class="flex items-center justify-between px-8 pb-4 lg:border-b-4 lg:border-border/20"
			>
				<h2
					class="text-xl font-black text-heading italic uppercase tracking-tighter"
				>
					Capas
				</h2>
				<button
					id="open-modal-btn"
					class="cottage-btn-primary py-2! px-4! text-[9px]!"
				>
					+ Nueva
				</button>
			</header>

			<div
				id="layers-list"
				class="flex-1 overflow-y-auto px-4 custom-scrollbar pb-20"
			>
				{sortedLayers.map((layer) => <LayerCard layer={layer} />)}
			</div>
		</div>

		<div
			id="sheet-overlay"
			class="fixed inset-0 bg-heading/20 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity lg:hidden z-40"
		>
		</div>

		<!-- Mobile Export Button (Floating) -->
		<button
			id="export-btn-mobile"
			disabled
			class="lg:hidden fixed bottom-6 right-6 px-6 py-3
           bg-primary text-white rounded-full
           flex items-center justify-center gap-2 text-sm font-black uppercase tracking-widest z-49
           transition-all duration-300
           shadow-[0_10px_25px_rgba(255,181,194,0.4)]
           disabled:opacity-60
           disabled:bg-bg
           disabled:text-muted/60
           disabled:border-2
           disabled:border-dashed
           disabled:border-border
           disabled:shadow-none
           disabled:grayscale
           active:scale-95 touch-none"
		>
			<span class="text-lg disabled:opacity-50">✨</span>
			<span>Exportar</span>
		</button>
	</main>

	<!-- New Layer Modal  -->
	<Modal id="new-layer-modal" title="Nueva Capa">
		<div class="space-y-8 p-2">
			<div>
				<label class="cottage-label">Nombre de la Capa</label>
				<input
					type="text"
					id="layer-name-input"
					placeholder="ej: Sombras Mágicas"
					class="w-full bg-bg border-4 border-border/40 rounded-full px-6 py-4 text-heading outline-none focus:border-primary focus:bg-white transition-all placeholder:text-muted/30 shadow-inner"
				/>
			</div>

			<label class="flex items-center gap-4 cursor-pointer group">
				<div class="relative flex items-center justify-center">
					<input
						type="checkbox"
						id="layer-hex-check"
						class="peer sr-only"
					/>
					<div
						class="w-8 h-8 rounded-full border-4 border-border bg-white peer-checked:bg-primary peer-checked:border-white transition-all shadow-sm"
					>
					</div>
					<svg
						class="absolute w-4 h-4 text-white scale-0 peer-checked:scale-100 transition-transform"
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="4"
						stroke-linecap="round"
						stroke-linejoin="round"
						><polyline points="20 6 9 17 4 12"></polyline></svg
					>
				</div>
				<span
					class="text-sm font-bold text-muted italic group-hover:text-heading transition-colors"
					>¿Esta capa usará colores?</span
				>
			</label>

			<div
				id="default-color-container"
				class="hidden animate-in fade-in zoom-in-95 duration-300"
			>
				<label class="cottage-label mb-3">Tono Inicial</label>
				<ColorPicker value="#FFB5C2" class="new-layer-color-picker" />
			</div>

			<div class="space-y-8 p-2">
				<div
					class="flex flex-col gap-3 pt-6 border-t-2 border-border/10"
				>
					<button
						id="confirm-layer-btn"
						class="w-full py-4 bg-primary text-white rounded-full font-black text-xs uppercase tracking-widest shadow-lg hover:scale-[1.02] active:scale-95 transition-all"
					>
						¡Crear Capa! ✨
					</button>
					<button
						type="button"
						onclick="window.closeModal('new-layer-modal')"
						class="w-full py-3 text-muted font-bold text-[10px] uppercase tracking-[0.2em] hover:text-heading transition-colors"
					>
						Tal vez luego (Cancelar)
					</button>
				</div>
			</div>
		</div>
	</Modal>

	<!-- TODO: Delete Layer Modal (Desktop) -->
	<!-- TODO: Edit Layer Modal (Desktop) -->
</Layout>

<script>
	import Sortable from "sortablejs";
	import { supabase } from "../../lib/supabase";
	import { updateCanvas } from "../../lib/editor/canvas";
	import { handleExport } from "../../lib/editor/export";
	import {
		initEditorElements,
		resetNewLayerModal,
		deleteVariant,
		deleteLayer,
		createLayer,
		toggleSheet,
	} from "../../lib/editor/layers";
	import { processImageUpload } from "../../lib/editor/images";
	import type { EditorState } from "../../lib/editor/types";

	document.addEventListener("DOMContentLoaded", () => {
		const state: EditorState = {};
		const UI = initEditorElements();

		// --- Exportar ---
		const runExport = () => handleExport(state, UI.projectName);
		document
			.getElementById("export-btn-desktop")
			?.addEventListener("click", runExport);
		document
			.getElementById("export-btn-mobile")
			?.addEventListener("click", runExport);

		// --- Init Capas ---
		document.querySelectorAll(".layer-card").forEach((card) => {
			const el = card as HTMLElement;
			const id = el.dataset.layerId!;
			const pickerWrapper = el.querySelector(
				".layer-color-picker-wrapper",
			);
			const internalPicker = pickerWrapper?.querySelector(
				".magic-picker-dot",
			) as HTMLInputElement;

			state[id] = {
				url: null,
				urlMaster: null,
				color: internalPicker?.value || "#ffffff",
				z: parseInt(el.dataset.z!),
				supportHex: el.dataset.supportHex === "true",
			};

			pickerWrapper?.addEventListener("colorChange", (e: any) => {
				state[id].color = e.detail;
				updateCanvas(state, UI.canvas, UI.placeholder);
			});

			el.querySelectorAll(".variant-item").forEach((btn) => {
				btn.addEventListener("click", () => {
					el.querySelectorAll(".variant-item").forEach((b) =>
						b.classList.remove("ring-4", "border-primary"),
					);
					const btnEl = btn as HTMLElement;
					state[id].url = btnEl.dataset.url || null;
					state[id].urlMaster =
						btnEl.dataset.master || btnEl.dataset.url || null;
					if (state[id].url)
						btnEl.classList.add("ring-4", "border-primary");
					updateCanvas(state, UI.canvas, UI.placeholder);
				});
			});

			// Subida de imagen
			el.querySelector(".file-upload-input")?.addEventListener(
				"change",
				async (e: any) => {
					const file = e.target.files[0];
					if (!file) return;
					window.showToast("Cosechando imagen...", "info");
					try {
						const { master, proxy } =
							await processImageUpload(file);
						const fd = new FormData();
						fd.append("file_master", master);
						fd.append("file_proxy", proxy);
						fd.append("layerId", id);
						const res = await fetch("/api/upload-variant", {
							method: "POST",
							body: fd,
						});
						if (res.ok) window.location.reload();
					} catch (err) {
						window.showToast("Error al subir", "error");
					}
				},
			);
		});

		document
			.getElementById("sheet-handle")
			?.addEventListener("click", () => {
				toggleSheet(UI);
			});

		document
			.getElementById("sheet-overlay")
			?.addEventListener("click", () => {
				toggleSheet(UI);
			});

		// --- Nueva Capa: Apertura ---
		document
			.getElementById("open-modal-btn")
			?.addEventListener("click", () => {
				resetNewLayerModal(UI);
				window.openModal("new-layer-modal");
			});

		// --- Nueva Capa: Confirmación ---
		document
			.getElementById("confirm-layer-btn")
			?.addEventListener("click", async () => {
				await createLayer(UI, state);
			});

		// --- Borrados ---
		document
			.querySelectorAll(".delete-layer-btn")
			.forEach((btn) =>
				btn.addEventListener("click", () =>
					deleteLayer(btn as HTMLButtonElement),
				),
			);

		document.querySelectorAll(".delete-variant-btn").forEach((btn) =>
			btn.addEventListener("click", (e) => {
				e.stopPropagation();
				deleteVariant(
					(btn as HTMLElement).dataset.id!,
					btn as HTMLButtonElement,
				);
			}),
		);

		// --- Drag & Drop ---
		if (UI.list) {
			Sortable.create(UI.list, {
				handle: ".drag-handle",
				animation: 150,
				onEnd: async () => {
					window.showToast("Sincronizando...", "info");

					const listContainer =
						document.getElementById("layers-list");
					if (!listContainer) return;

					const cards = Array.from(
						listContainer.children,
					) as HTMLElement[];

					const updates = cards.map((card, index) => {
						const id = card.dataset.layerId;
						const name = card.dataset.layerName;
						const newZ = (cards.length - 1 - index) * 10;

						if (state[id!]) {
							state[id!].z = newZ;
						}

						const badge = card.querySelector(".z-badge");
						if (badge) badge.textContent = `#${newZ}`;
						card.dataset.z = newZ.toString();

						return {
							id: id,
							name: name,
							new_z: newZ,
						};
					});

					updateCanvas(state, UI.canvas, UI.placeholder);

					console.log("Enviando actualizaciones:", updates);

					const { error } = await supabase.rpc(
						"update_layers_order",
						{
							layer_updates: updates,
						},
					);

					if (error) {
						window.showToast("Error al guardar orden", "error");
						console.error(error);
					} else {
						window.showToast("Orden actualizado", "success");
					}
				},
			});
		}

		// --- Color Picker Toggle ---
		UI.hexCheck?.addEventListener("change", (e) => {
			const isChecked = (e.target as HTMLInputElement).checked;

			if (isChecked) {
				UI.defaultColorContainer?.classList.remove("hidden");
				UI.defaultColorContainer?.classList.add(
					"animate-in",
					"fade-in",
					"slide-in-from-top-2",
				);
			} else {
				UI.defaultColorContainer?.classList.add("hidden");
			}
		});
	});
</script>
