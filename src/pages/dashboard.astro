---
// src/pages/dashboard.astro
import Layout from "../layouts/Layout.astro";
---

<Layout title="Mis Proyectos | Layerly">
	<div
		id="loading"
		class="text-primary font-bold animate-bounce text-center w-full italic"
	>
		Preparando el jardín...
	</div>

	<div
		id="dashboard-content"
		class="hidden w-full max-w-5xl p-6 sm:p-12 bg-surface/90 rounded-[3rem] shadow-[0_20px_60px_rgba(255,181,194,0.2)] border-4 border-white relative overflow-hidden backdrop-blur-md"
	>
		<div
			class="absolute -top-10 -right-10 w-40 h-40 bg-primary/10 rounded-full blur-3xl pointer-events-none"
		>
		</div>
		<div
			class="absolute -bottom-10 -left-10 w-40 h-40 bg-secondary/10 rounded-full blur-3xl pointer-events-none"
		>
		</div>

		<div class="relative z-10 w-full">
			<div
				class="flex flex-col sm:flex-row sm:items-center justify-between gap-6 mb-10 border-b-2 border-border pb-8"
			>
				<div>
					<h1
						class="text-3xl sm:text-4xl font-black tracking-tight text-heading italic"
					>
						Hola, <span id="user-display" class="text-primary"
							>Usuario</span
						>
					</h1>
					<p class="text-muted mt-2 text-sm font-medium italic">
						¿Qué vamos a crear hoy en nuestro rincón?
					</p>
				</div>
				<button
					id="logout-btn"
					class="px-6 py-2.5 rounded-full text-xs font-bold bg-bg hover:bg-accent text-slate-500 transition-all border-2 border-transparent hover:border-primary/20 shrink-0 uppercase tracking-widest"
				>
					Descansar (Salir)
				</button>
			</div>

			<div>
				<div class="flex items-center justify-between mb-8">
					<h2
						class="text-xl font-black text-text/80 uppercase tracking-tighter italic"
					>
						Colección de Avatares
					</h2>
					<button
						id="new-project-btn"
						class="px-8 py-3 bg-primary hover:scale-105 text-white text-sm font-bold rounded-full transition-all shadow-[0_10px_20px_rgba(255,181,194,0.3)]"
					>
						+ Nuevo Proyecto
					</button>
				</div>

				<div
					id="projects-skeleton"
					class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8"
				>
					{
						[1, 2, 3].map(() => (
							<div class="bg-bg/50 h-[200px] rounded-[2rem] border-2 border-dashed border-accent animate-pulse" />
						))
					}
				</div>

				<div
					id="projects-grid"
					class="hidden grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8"
				>
				</div>

				<div
					id="empty-state"
					class="hidden text-center py-16 px-6 border-4 border-dashed border-border rounded-[3rem] bg-bg/30"
				>
					<div class="text-6xl mb-4">🌸</div>
					<h3 class="text-xl font-bold text-muted italic">
						El jardín está vacío
					</h3>
					<p class="mt-2 text-sm text-muted mb-8 italic">
						Comienza tu primera aventura mágica ahora mismo.
					</p>
					<button
						id="empty-new-btn"
						class="px-10 py-4 bg-white border-2 border-primary text-primary hover:bg-primary hover:text-white text-sm font-bold rounded-full transition-all"
					>
						Plantar un Proyecto
					</button>
				</div>
			</div>
		</div>
	</div>

	<dialog
		id="new-project-modal"
		class="bg-white border-4 border-primary/20 rounded-[2.5rem] shadow-2xl p-0 backdrop:backdrop-blur-sm w-[90%] max-w-md m-auto overflow-hidden"
	>
		<div class="p-10">
			<h3 class="text-2xl font-black text-text italic mb-2">
				Nuevo Retrato
			</h3>
			<p class="text-sm text-slate-400 mb-8 italic">
				¿Cómo se llamará esta nueva criatura?
			</p>

			<input
				type="text"
				id="project-name-input"
				placeholder="Nombre del proyecto..."
				class="block w-full px-6 py-4 bg-bg border-2 border-transparent rounded-full placeholder-slate-300 focus:outline-none focus:border-primary transition-all mb-8 text-text"
			/>

			<div class="flex gap-4">
				<button
					id="cancel-project-btn"
					class="flex-1 py-4 text-xs font-bold uppercase tracking-widest text-slate-400 hover:text-text transition-colors"
					>Atrás</button
				>
				<button
					id="confirm-project-btn"
					class="flex-2 py-4 bg-primary text-white rounded-full font-bold shadow-lg hover:scale-105 transition-all"
					>Crear</button
				>
			</div>
		</div>
	</dialog>
</Layout>

<script>
	import { supabase } from "../lib/supabase";

	document.addEventListener("DOMContentLoaded", async () => {
		const loading = document.getElementById("loading");
		const content = document.getElementById("dashboard-content");

		const projectsSkeleton = document.getElementById("projects-skeleton");
		const projectsGrid = document.getElementById("projects-grid");
		const emptyState = document.getElementById("empty-state");

		// Validar sesión activa
		const {
			data: { session },
			error,
		} = await supabase.auth.getSession();

		if (error || !session) {
			window.location.replace("/");
			return;
		}

		// Rellenar cabecera con el saludo
		const user = session.user;
		const userDisplay = document.getElementById("user-display");
		if (userDisplay) {
			// Usa el nombre que haya antes del '@' del correo
			userDisplay.textContent = user.email
				? user.email.split("@")[0]
				: "Usuario";
		}

		// Ocultar pantalla de carga del layout inicial y mostrar tablero
		if (loading) loading.classList.add("hidden");
		if (content) content.classList.remove("hidden");

		// Rutina para cargar los proyectos desde Supabase
		const loadProjects = async () => {
			if (projectsSkeleton) projectsSkeleton.classList.remove("hidden");
			if (projectsGrid) projectsGrid.classList.add("hidden");
			if (emptyState) emptyState.classList.add("hidden");

			const { data: projects, error: dbError } = await supabase
				.from("avatar_config")
				.select("*")
				.eq("user_id", user.id)
				.order("created_at", { ascending: false });

			if (projectsSkeleton) projectsSkeleton.classList.add("hidden");

			if (!projects || projects.length === 0) {
				emptyState?.classList.remove("hidden");
				return;
			}

			if (projectsGrid) {
				projectsGrid.innerHTML = "";
				projects.forEach((proj) => {
					const date = new Date(proj.created_at).toLocaleDateString(
						"es-ES",
						{
							year: "numeric",
							month: "short",
							day: "numeric",
						},
					);

					const card = document.createElement("div");
					card.className =
						"group relative bg-slate-900/40 p-5 rounded-3xl border border-accent/40 hover:border-primary/50 transition-all flex flex-col justify-between min-h-[180px]";

					card.innerHTML = `
                <button class="delete-project-btn absolute top-5 right-5 p-2.5 text-slate-500 hover:text-red-500 hover:bg-red-500/10 rounded-xl opacity-0 group-hover:opacity-100 transition-all" data-id="${proj.id}" data-name="${proj.project_name}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18m-2 0v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6m3 0V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path></svg>
                </button>
                <div>
                    <h3 class="text-lg font-black text-white group-hover:text-primary transition-colors pr-10 italic uppercase">${proj.project_name}</h3>
                    <p class="text-[10px] font-bold text-slate-500 mt-2 uppercase tracking-widest">${date}</p>
                </div>
                <div class="mt-6">
                    <a href="/editor/${proj.id}" class="w-full inline-flex items-center justify-center py-3 px-4 rounded-xl bg-white/5 border border-white/10 text-sm font-bold text-secondary hover:bg-primary hover:text-white transition-all">
                        ABRIR EDITOR
                    </a>
                </div>
            `;

					// Listener de borrado para cada tarjeta
					card.querySelector(".delete-project-btn")?.addEventListener(
						"click",
						async (e) => {
							const btn = e.currentTarget as HTMLElement;
							const { id, name } = btn.dataset;

							if (
								!confirm(
									`¿Eliminar "${name}"? Se borrarán todos los assets de Cloudinary.`,
								)
							)
								return;

							window.showToast("Limpiando proyecto...", "info");
							btn.innerHTML =
								'<div class="w-4 h-4 border-2 border-red-500 border-t-transparent rounded-full animate-spin"></div>';

							const res = await fetch("/api/delete-project", {
								method: "POST",
								body: JSON.stringify({ projectId: id }),
								headers: { "Content-Type": "application/json" },
							});

							if (res.ok) {
								window.showToast(
									"Proyecto eliminado",
									"success",
								);
								loadProjects(); // Recarga la lista sin refrescar la página
							} else {
								window.showToast("Error al borrar", "error");
								loadProjects();
							}
						},
					);

					projectsGrid.appendChild(card);
				});
				projectsGrid.classList.remove("hidden");
			}
		};

		// LLama a pintar interfaz
		await loadProjects();

		// Lógica del Modal para "+ Nuevo Proyecto"
		const modal = document.getElementById(
			"new-project-modal",
		) as HTMLDialogElement;
		const nameInput = document.getElementById(
			"project-name-input",
		) as HTMLInputElement;
		const cancelBtn = document.getElementById("cancel-project-btn");
		const confirmBtn = document.getElementById("confirm-project-btn");
		const btnText = document.getElementById("btn-text");
		const btnSpinner = document.getElementById("btn-spinner");

		const openModal = () => {
			if (nameInput) nameInput.value = "";
			if (modal) modal.showModal();
		};

		const closeModal = () => {
			if (modal) modal.close();
		};

		const executeCreateProject = async () => {
			if (!nameInput) return;
			const name = nameInput.value;
			if (!name || name.trim() === "") {
				nameInput.focus();
				return;
			}

			// UI loading state
			if (btnText) btnText.textContent = "Creando...";
			if (btnSpinner) btnSpinner.classList.remove("hidden");
			if (confirmBtn) confirmBtn.setAttribute("disabled", "true");

			// Hacer un Insert y retornar la row ingresada para obtener el ID
			const { data, error: insertError } = await supabase
				.from("avatar_config")
				.insert([
					{
						project_name: name.trim(),
						user_id: user.id,
					},
				])
				.select()
				.single();

			if (insertError) {
				alert("Hubo un error al crear el proyecto. Revisa la consola.");
				console.error("Insert Error:", insertError);

				// Restaurar boton
				if (btnText) btnText.textContent = "Crear Proyecto";
				if (btnSpinner) btnSpinner.classList.add("hidden");
				if (confirmBtn) confirmBtn.removeAttribute("disabled");
			} else if (data) {
				// Redirigir al generador Picrew editor enviando el ID por el parametro de ruta
				window.location.href = `/editor/${data.id}`;
			}
		};

		// Añadir bindings del modal
		document
			.getElementById("new-project-btn")
			?.addEventListener("click", openModal);
		document
			.getElementById("empty-new-btn")
			?.addEventListener("click", openModal);

		cancelBtn?.addEventListener("click", closeModal);
		confirmBtn?.addEventListener("click", executeCreateProject);
		nameInput?.addEventListener("keydown", (e) => {
			if (e.key === "Enter") executeCreateProject();
		});
	});

	// Bind de Cerrar Sesion
	document
		.getElementById("logout-btn")
		?.addEventListener("click", async () => {
			// 1. Cerrar sesión en Supabase
			await supabase.auth.signOut();

			// 2. Borrar cookies manualmente (poniendo una fecha pasada)
			document.cookie =
				"sb-access-token=; path=/; expires=Thu, 01 Jan 1970 00:00:00 UTC;";
			document.cookie =
				"sb-refresh-token=; path=/; expires=Thu, 01 Jan 1970 00:00:00 UTC;";

			// 3. Redirigir
			window.location.href = "/";
		});

	// Escuchar deslogueos remotos
	supabase.auth.onAuthStateChange((event, session) => {
		if (event === "SIGNED_OUT" || !session) {
			window.location.replace("/");
		}
	});
</script>
