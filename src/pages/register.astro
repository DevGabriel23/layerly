---
// src/pages/register.astro
import DiscordIcon from "../components/icons/DiscordIcon.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Layerly | Crear Cuenta">
	<div
		class="w-full max-w-md p-10 bg-surface/80 rounded-[3rem] shadow-[0_20px_50px_rgba(255,181,194,0.3)] border-4 border-white relative overflow-hidden backdrop-blur-md"
	>
		<div class="absolute top-0 right-0 p-4 opacity-20">
			<svg
				width="60"
				height="60"
				viewBox="0 0 24 24"
				fill="var(--theme-primary)"
			>
				<path
					d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
				></path>
			</svg>
		</div>

		<div class="text-center relative z-10 mb-10">
			<h1
				class="text-5xl font-bold tracking-tight text-primary drop-shadow-sm mb-2"
				style="font-family: 'Quicksand', sans-serif;"
			>
				Layerly
			</h1>
			<p class="text-slate-400 font-medium italic">
				Únete a nuestra pequeña comunidad...
			</p>
		</div>

		<form id="register-form" class="space-y-6 relative z-10">
			<div>
				<label
					class="block text-xs font-bold text-slate-400 uppercase tracking-widest ml-4 mb-2"
					>Correo Electrónico</label
				>
				<input
					id="email"
					name="email"
					type="email"
					required
					class="block w-full px-6 py-4 bg-bg border-2 border-transparent rounded-full shadow-sm placeholder-slate-300 focus:outline-none focus:border-primary focus:bg-white transition-all duration-300 text-slate-600"
					placeholder="tucorreo@ejemplo.com"
				/>
			</div>

			<div>
				<label
					class="block text-xs font-bold text-slate-400 uppercase tracking-widest ml-4 mb-2"
					>Contraseña</label
				>
				<input
					id="password"
					name="password"
					type="password"
					required
					class="block w-full px-6 py-4 bg-bg border-2 border-transparent rounded-full shadow-sm placeholder-slate-300 focus:outline-none focus:border-primary focus:bg-white transition-all duration-300 text-slate-600"
					placeholder="••••••••"
				/>
			</div>

			<div class="pt-2">
				<button
					type="submit"
					class="w-full py-4 px-4 rounded-full shadow-[0_10px_20px_rgba(255,181,194,0.4)] text-sm font-bold text-white bg-primary hover:scale-[1.03] active:scale-[0.97] transition-all duration-300"
				>
					Comenzar Aventura
				</button>

				<div
					id="error-message"
					class="mt-4 text-xs font-bold text-red-400 hidden rounded-2xl bg-red-50 p-4 border border-red-100 text-center animate-bounce"
				>
				</div>
				<div
					id="success-message"
					class="mt-4 text-xs font-bold text-emerald-500 hidden rounded-2xl bg-emerald-50 p-4 border border-emerald-100 text-center"
				>
				</div>
			</div>
		</form>

		<div class="mt-8 relative">
			<div class="absolute inset-0 flex items-center">
				<div class="w-full border-t border-primary/20"></div>
			</div>
			<div class="relative flex justify-center">
				<span
					class="px-4 bg-white text-[10px] uppercase tracking-[0.2em] text-slate-300 font-bold"
				>
					Portal alternativo
				</span>
			</div>
		</div>

		<div class="mt-6 flex justify-center">
			<button
				id="btn-discord"
				type="button"
				class="flex items-center gap-3 px-10 py-3 bg-white border-2 border-primary/20 rounded-full text-sm font-bold text-slate-500 hover:bg-primary/10 hover:border-primary/40 hover:scale-105 transition-all duration-300"
			>
				<DiscordIcon class="w-5 h-5 text-[#5865F2]" />
				Discord
			</button>
		</div>

		<div class="text-center mt-10">
			<a
				href="/"
				class="text-xs font-bold text-slate-400 hover:text-secondary transition-colors uppercase tracking-widest"
			>
				¿Ya eres parte? <span
					class="text-secondary underline underline-offset-4 ml-1"
					>Inicia sesión</span
				>
			</a>
		</div>
	</div>

	<script>
		import {
			registerWithEmail,
			loginWithDiscord,
		} from "../lib/auth-helpers";

		const registerForm = document.getElementById(
			"register-form",
		) as HTMLFormElement;
		const errorMessage = document.getElementById("error-message");
		const successMessage = document.getElementById("success-message");
		const submitBtn = registerForm?.querySelector(
			'button[type="submit"]',
		) as HTMLButtonElement;

		const clearMessages = () => {
			errorMessage?.classList.add("hidden");
			successMessage?.classList.add("hidden");
		};

		const showError = (message: string) => {
			if (errorMessage) {
				errorMessage.textContent = message;
				errorMessage.classList.remove("hidden");
			}
		};

		const showSuccess = (message: string) => {
			if (successMessage) {
				successMessage.textContent = message;
				successMessage.classList.remove("hidden");
			}
		};

		registerForm?.addEventListener("submit", async (e) => {
			e.preventDefault();
			clearMessages();

			if (submitBtn) {
				submitBtn.disabled = true;
				submitBtn.textContent = "Preparando tu jardín...";
			}

			const formData = new FormData(registerForm);
			const email = formData.get("email") as string;
			const password = formData.get("password") as string;

			try {
				const { data, error } = await registerWithEmail(
					email,
					password,
				);

				if (error) {
					showError(error.message);
					return;
				}

				if (data.user && !data.session) {
					showSuccess(
						"🕊️ ¡Mensaje enviado! Revisa tu correo para confirmar tu cuenta.",
					);
					registerForm.reset();
				} else if (data.session) {
					const { access_token, refresh_token } = data.session;
					const maxAge = 60 * 60 * 24 * 7;
					document.cookie = `sb-access-token=${access_token}; path=/; max-age=${maxAge}; SameSite=Lax; Secure`;
					document.cookie = `sb-refresh-token=${refresh_token}; path=/; max-age=${maxAge}; SameSite=Lax; Secure`;

					showSuccess("✨ ¡Cuenta creada! Entrando...");
					setTimeout(
						() => (window.location.href = "/dashboard"),
						1000,
					);
				}
			} catch (err) {
				showError(
					"Hubo un problema al crear tu cuenta. Inténtalo de nuevo.",
				);
			} finally {
				if (submitBtn) {
					submitBtn.disabled = false;
					submitBtn.textContent = "Comenzar Aventura";
				}
			}
		});

		document
			.getElementById("btn-discord")
			?.addEventListener("click", async () => {
				const { error } = await loginWithDiscord();
				if (error) showError(`Error con Discord: ${error.message}`);
			});
	</script>
</Layout>
