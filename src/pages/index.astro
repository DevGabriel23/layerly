---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";
import { supabase } from "../lib/supabase";

const {
	data: { user },
} = await supabase.auth.getUser();

if (user) return redirect("/dashboard");
---

<Layout title="Iniciar Sesión">
	<div
		class="w-full max-w-md p-8 bg-surface rounded-3xl shadow-2xl border border-accent/50 relative overflow-hidden backdrop-blur-xl"
	>
		<!-- Decoraciones de fondo -->
		<div
			class="absolute -top-24 -right-24 w-64 h-64 bg-secondary rounded-full mix-blend-screen filter blur-[80px] opacity-30 animate-pulse"
		>
		</div>
		<div
			class="absolute -bottom-24 -left-24 w-64 h-64 bg-primary rounded-full mix-blend-screen filter blur-[80px] opacity-30 animate-pulse"
			style="animation-delay: 2s;"
		>
		</div>

		<div class="text-center relative z-10 mb-8">
			<h2
				class="text-4xl font-extrabold tracking-tight bg-linear-to-br from-secondary via-primary to-secondary bg-clip-text text-transparent drop-shadow-sm pb-1"
			>
				Bienvenido
			</h2>
			<p class="mt-3 text-sm text-slate-400 font-medium">
				Inicia sesión en tu cuenta para continuar
			</p>
		</div>

		<div class="space-y-6 relative z-10">
			<form id="login-form" class="space-y-5">
				<div>
					<label
						for="email"
						class="block text-sm font-semibold text-slate-300 ml-1 mb-1.5"
						>Correo Electrónico</label
					>
					<input
						id="email"
						name="email"
						type="email"
						autocomplete="email"
						required
						class="appearance-none block w-full px-5 py-3.5 bg-slate-900/50 border border-accent/50 rounded-2xl shadow-inner placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-all duration-300 hover:border-accent backdrop-blur-sm"
						placeholder="tucorreo@ejemplo.com"
					/>
				</div>

				<div>
					<label
						for="password"
						class="block text-sm font-semibold text-slate-300 ml-1 mb-1.5"
						>Contraseña</label
					>
					<input
						id="password"
						name="password"
						type="password"
						autocomplete="current-password"
						required
						class="appearance-none block w-full px-5 py-3.5 bg-slate-900/50 border border-accent/50 rounded-2xl shadow-inner placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-all duration-300 hover:border-accent backdrop-blur-sm"
						placeholder="••••••••"
					/>
				</div>

				<div class="pt-2">
					<button
						type="submit"
						class="w-full flex justify-center py-4 px-4 border border-transparent rounded-2xl shadow-lg text-sm font-bold text-white bg-linear-to-r from-secondary to-primary hover:brightness-110 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-secondary focus:ring-offset-slate-900 transition-all duration-300 hover:scale-[1.02] active:scale-[0.98]"
					>
						Iniciar Sesión
					</button>
					<div
						id="error-message"
						class="mt-3 text-sm font-medium text-red-400 hidden rounded-xl bg-red-950/30 p-3 border border-red-900/50 text-center"
					>
					</div>
					<div
						id="success-message"
						class="mt-3 text-sm font-medium text-emerald-400 hidden rounded-xl bg-emerald-950/30 p-3 border border-emerald-900/50 text-center"
					>
					</div>
				</div>
			</form>

			<div class="mt-8 relative">
				<div class="absolute inset-0 flex items-center">
					<div class="w-full border-t border-accent/60"></div>
				</div>
				<div
					class="relative flex justify-center text-xs uppercase font-semibold tracking-wider"
				>
					<span class="px-3 bg-surface text-slate-400"
						>O continúa con</span
					>
				</div>
			</div>

			<div class="mt-6 grid grid-cols-1 gap-4">
				<!-- <button
						type="button"
						id="btn-google"
						class="w-full inline-flex justify-center items-center py-3 px-4 border border-accent/50 rounded-2xl shadow-sm bg-accent/20 hover:bg-accent/40 text-sm font-medium text-slate-300 focus:outline-none focus:ring-2 focus:ring-secondary transition-all duration-300 hover:scale-105 active:scale-95"
					>
						<svg
							class="h-5 w-5"
							viewBox="0 0 24 24"
							fill="none"
							xmlns="http://www.w3.org/2000/svg"
						>
							<path
								d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
								fill="#4285F4"></path>
							<path
								d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
								fill="#34A853"></path>
							<path
								d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
								fill="#FBBC05"></path>
							<path
								d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
								fill="#EA4335"></path>
						</svg>
						<span class="sr-only">Google</span>
					</button> -->

				<!-- <button
						type="button"
						id="btn-facebook"
						class="w-full inline-flex justify-center items-center py-3 px-4 border border-accent/50 rounded-2xl shadow-sm bg-accent/20 hover:bg-accent/40 text-sm font-medium text-slate-300 focus:outline-none focus:ring-2 focus:ring-secondary transition-all duration-300 hover:scale-105 active:scale-95"
					>
						<svg
							class="h-5 w-5 text-[#1877F2]"
							fill="currentColor"
							viewBox="0 0 24 24"
							aria-hidden="true"
						>
							<path
								fill-rule="evenodd"
								d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"
								clip-rule="evenodd"></path>
						</svg>
						<span class="sr-only">Facebook</span>
					</button> -->

				<button
					type="button"
					id="btn-discord"
					class="w-full inline-flex justify-center items-center py-3 px-4 border border-accent/50 rounded-2xl shadow-sm bg-accent/20 hover:bg-accent/40 text-sm font-medium text-slate-300 focus:outline-none focus:ring-2 focus:ring-secondary transition-all duration-300 hover:scale-105 active:scale-95"
				>
					<svg
						class="h-5 w-5 text-[#5865F2] mr-2"
						fill="currentColor"
						viewBox="0 0 127.14 96.36"
						aria-hidden="true"
					>
						<path
							d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.7,77.7,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1A105.25,105.25,0,0,0,126.6,80.22h0C129.24,52.84,122.09,29.11,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53s5-12.74,11.43-12.74S54,46,53.89,53,48.84,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.31,60,73.31,53s5-12.74,11.43-12.74S96.33,46,96.22,53,91.08,65.69,84.69,65.69Z"
						></path>
					</svg>
					<span>Discord</span>
				</button>
			</div>

			<p class="mt-8 text-center text-sm text-slate-400">
				¿No tienes una cuenta? <a
					href="/register"
					class="font-semibold text-primary hover:brightness-110 transition-colors"
					>Regístrate</a
				>
			</p>
		</div>
	</div>

	<script>
		import { loginWithEmail, loginWithDiscord } from "../lib/auth-helpers";

		const loginForm = document.getElementById(
			"login-form",
		) as HTMLFormElement;
		const errorMessage = document.getElementById("error-message");

		loginForm?.addEventListener("submit", async (e) => {
			e.preventDefault();
			const formData = new FormData(loginForm);
			const email = formData.get("email") as string;
			const password = formData.get("password") as string;

			const { data, error } = await loginWithEmail(email, password);

			if (error) {
				if (errorMessage) {
					errorMessage.textContent = error.message;
					errorMessage.classList.remove("hidden");
				}
				return;
			}

			if (data.session) {
				const { access_token, refresh_token } = data.session;
				// Guardar cookies con expiración de 7 días
				const maxAge = 60 * 60 * 24 * 7;
				document.cookie = `sb-access-token=${access_token}; path=/; max-age=${maxAge}; SameSite=Lax; Secure`;
				document.cookie = `sb-refresh-token=${refresh_token}; path=/; max-age=${maxAge}; SameSite=Lax; Secure`;

				window.location.href = "/dashboard";
			}
		});

		document
			.getElementById("btn-discord")
			?.addEventListener("click", () => loginWithDiscord());
	</script>
</Layout>
