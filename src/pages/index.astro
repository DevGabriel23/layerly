---
// src/pages/index.astro
import DiscordIcon from "../components/icons/DiscordIcon.astro";
import Layout from "../layouts/Layout.astro";
import { supabase } from "../lib/supabase";

const {
	data: { user },
} = await supabase.auth.getUser();

if (user) return Astro.redirect("/dashboard");
---

<Layout title="Layerly | Bienvenido">
	<div
		class="w-full max-w-md p-10 bg-surface/80 rounded-[3rem] shadow-[0_20px_50px_rgba(255,181,194,0.3)] border-4 border-white relative overflow-hidden backdrop-blur-md"
	>
		<div class="absolute top-0 right-0 p-4 opacity-20">
			<svg
				width="60"
				height="60"
				viewBox="0 0 24 24"
				fill="var(--theme-primary)"
				><path
					d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
				></path></svg
			>
		</div>

		<div class="text-center relative z-10 mb-10">
			<h1
				class="text-5xl font-bold tracking-tight text-primary drop-shadow-sm mb-2"
				style="font-family: 'Quicksand', sans-serif;"
			>
				Layerly
			</h1>
			<p class="text-slate-400 font-medium italic">
				Crea tu pequeño mundo...
			</p>
		</div>

		<div class="space-y-6 relative z-10">
			<form id="login-form" class="space-y-5">
				<div>
					<label
						class="block text-xs font-bold text-slate-400 uppercase tracking-widest ml-4 mb-2"
						>Correo electrónico</label
					>
					<input
						id="email"
						name="email"
						type="email"
						autocomplete="email"
						required
						class="block w-full px-6 py-4 bg-bg border-2 border-transparent rounded-full shadow-sm placeholder-slate-300 focus:outline-none focus:border-primary focus:bg-white transition-all duration-300 text-text"
						placeholder="tucorreo@ejemplo.com"
					/>
				</div>

				<div>
					<label
						class="block text-xs font-bold text-slate-400 uppercase tracking-widest ml-4 mb-2"
						>Contraseña</label
					>
					<input
						id="password"
						name="password"
						type="password"
						autocomplete="current-password"
						required
						class="block w-full px-6 py-4 bg-bg border-2 border-transparent rounded-full shadow-sm placeholder-slate-300 focus:outline-none focus:border-primary focus:bg-white transition-all duration-300 text-text"
						placeholder="••••••••"
					/>
				</div>

				<div class="pt-2">
					<button
						type="submit"
						class="w-full py-4 px-4 rounded-full shadow-[0_10px_20px_rgba(255,181,194,0.4)] text-sm font-bold text-white bg-primary hover:scale-[1.03] active:scale-[0.97] transition-all duration-300"
					>
						Iniciar Sesión
					</button>
					<div
						id="error-message"
						class="mt-3 text-sm font-medium text-red-400 hidden rounded-xl bg-red-950/30 p-3 border border-red-900/50 text-center"
					>
					</div>
					<div
						id="success-message"
						class="mt-3 text-sm font-medium text-emerald-400 hidden rounded-xl bg-emerald-950/30 p-3 border border-emerald-900/50 text-center"
					>
					</div>
				</div>
			</form>

			<div class="relative py-4">
				<div class="absolute inset-0 flex items-center">
					<div class="w-full border-t border-primary/20"></div>
				</div>
				<div class="relative flex justify-center">
					<span
						class="px-4 bg-white text-[10px] uppercase tracking-[0.2em] text-slate-400 font-bold"
					>
						Portal alternativo
					</span>
				</div>
			</div>

			<div class="flex justify-center">
				<button
					id="btn-discord"
					type="button"
					class="flex items-center gap-3 px-10 py-3 bg-white border-2 border-primary/20 rounded-full text-sm font-bold text-slate-500 hover:bg-primary/10 hover:border-primary/40 hover:scale-105 transition-all duration-300"
				>
					<DiscordIcon class="w-5 h-5 text-[#5865F2]" />
					Discord
				</button>
			</div>

			<div class="text-center mt-8">
				<a
					href="/register"
					class="text-xs font-bold text-slate-400 hover:text-primary transition-colors uppercase tracking-widest"
				>
					¿Aún no tienes cuenta? <span
						class="text-primary underline underline-offset-4 ml-1"
						>Regístrate</span
					>
				</a>
			</div>
		</div>
	</div>

	<script>
		import { loginWithEmail, loginWithDiscord } from "../lib/auth-helpers";

		const loginForm = document.getElementById(
			"login-form",
		) as HTMLFormElement;
		const errorMessage = document.getElementById("error-message");

		loginForm?.addEventListener("submit", async (e) => {
			e.preventDefault();
			const formData = new FormData(loginForm);
			const email = formData.get("email") as string;
			const password = formData.get("password") as string;

			const { data, error } = await loginWithEmail(email, password);

			if (error) {
				if (errorMessage) {
					errorMessage.textContent = error.message;
					errorMessage.classList.remove("hidden");
				}
				return;
			}

			if (data.session) {
				const { access_token, refresh_token } = data.session;
				// Guardar cookies con expiración de 7 días
				const maxAge = 60 * 60 * 24 * 7;
				document.cookie = `sb-access-token=${access_token}; path=/; max-age=${maxAge}; SameSite=Lax; Secure`;
				document.cookie = `sb-refresh-token=${refresh_token}; path=/; max-age=${maxAge}; SameSite=Lax; Secure`;

				window.location.href = "/dashboard";
			}
		});

		document
			.getElementById("btn-discord")
			?.addEventListener("click", () => loginWithDiscord());
	</script>
</Layout>
