---
interface Props {
	id: string;
	name: string;
	date: string;
}

const { id, name, date } = Astro.props;
---

<div
	class="project-card bg-slate-900/40 p-5 rounded-2xl border border-accent/40 shadow-inner hover:border-primary/50 transition-all flex flex-col justify-between min-h-[180px] group relative"
>
	<button
		class="delete-project-btn absolute top-4 right-4 p-2 text-slate-500 hover:text-red-500 opacity-0 group-hover:opacity-100 transition-all"
		title="Eliminar proyecto"
	>
		<svg
			xmlns="http://www.w3.org/2000/svg"
			width="18"
			height="18"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			><path
				d="M3 6h18m-2 0v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6m3 0V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"
			></path></svg
		>
		<div
			class="w-3 h-3 hidden border-2 border-white border-t-transparent rounded-full animate-spin"
		>
		</div>
	</button>

	<div>
		<h3
			class="text-lg font-bold text-white group-hover:text-primary transition-colors leading-tight pr-8"
		>
			{name}
		</h3>
		<p class="text-xs font-medium text-slate-500 mt-2">Creado: {date}</p>
	</div>

	<div class="mt-4 pt-4 border-t border-accent/30 flex">
		<a
			href={`/editor/${id}`}
			class="inline-flex flex-1 items-center justify-center py-3 px-4 rounded-xl bg-primary/10 text-sm font-semibold text-secondary hover:text-primary transition-colors"
		>
			Editar Avatar
			<svg
				class="ml-1.5 w-4 h-4"
				fill="none"
				stroke="currentColor"
				viewBox="0 0 24 24"
				><path
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="2.5"
					d="M9 5l7 7-7 7"></path></svg
			>
		</a>
	</div>
</div>
