---
// src/components/editor/ColorPicker.astro
interface Props {
	value?: string;
	class?: string;
}

const { value = "#ffffff", class: className } = Astro.props;
---

<div
	class:list={[
		"magic-color-container flex items-center gap-2 bg-bg border-2 border-border/60 p-1.5 rounded-full shadow-inner",
		className,
	]}
>
	<div
		class="relative w-8 h-8 rounded-full border-2 border-white shadow-sm overflow-hidden shrink-0"
	>
		<input
			type="color"
			class="magic-picker-dot absolute inset-0 w-[200%] h-[200%] -translate-x-1/4 -translate-y-1/4 cursor-pointer border-none bg-transparent"
			value={value}
		/>
	</div>

	<div class="flex items-center pr-3">
		<span class="text-[10px] font-black text-muted mr-0.5">#</span>
		<input
			type="text"
			maxlength="6"
			class="magic-picker-text w-14 bg-transparent border-none outline-none text-xs font-black text-heading uppercase tracking-widest placeholder-muted/50"
			value={value.replace("#", "")}
			placeholder="FFFFFF"
		/>
	</div>
</div>

<style>
	/* Reset nativo para el input color */
	.magic-picker-dot::-webkit-color-swatch-wrapper {
		padding: 0;
	}
	.magic-picker-dot::-webkit-color-swatch {
		border: none;
		border-radius: 50%;
	}

	/* Eliminar flechitas de número si las hubiera y otros estilos */
	.magic-picker-text {
		font-family: "Quicksand", sans-serif;
	}
</style>

<script>
	// Lógica de sincronización para todos los MagicPickers de la página
	document.querySelectorAll(".magic-color-container").forEach((container) => {
		const dot = container.querySelector(
			".magic-picker-dot",
		) as HTMLInputElement;
		const text = container.querySelector(
			".magic-picker-text",
		) as HTMLInputElement;

		// Al cambiar el círculo de color
		dot.addEventListener("input", () => {
			text.value = dot.value.replace("#", "").toUpperCase();
			// Disparar evento custom para que el editor se entere
			container.dispatchEvent(
				new CustomEvent("colorChange", { detail: dot.value }),
			);
		});

		// Al escribir en el texto
		text.addEventListener("input", () => {
			let val = text.value.trim();
			if (val.length === 6) {
				const hex = `#${val}`;
				// Validar que sea un hexadecimal real
				if (/^#[0-9A-F]{6}$/i.test(hex)) {
					dot.value = hex;
					container.dispatchEvent(
						new CustomEvent("colorChange", { detail: hex }),
					);
				}
			}
		});

		// Evitar caracteres no válidos
		text.addEventListener("keypress", (e) => {
			if (!/[0-9a-fA-F]/.test(e.key)) e.preventDefault();
		});
	});
</script>
