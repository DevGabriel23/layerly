---
// src/layouts/Layout.astro
import Footer from "../components/ui/Footer.astro";
import "../styles/global.css";

interface Props {
	title: string;
}

const { title } = Astro.props;

export const Theme = {
	bg: "#FFF9F5", // Crema muy suave (papel antiguo)
	surface: "#FFFFFF", // Blanco puro para tarjetas
	primary: "#FFB5C2", // Rosa pastel suave
	secondary: "#A8D5BA", // Verde musgo/menta (toque natural)
	accent: "#F3E5F5", // Lavanda muy claro para detalles
	text: "#5D4037", // Marrón cálido (en lugar de negro puro)
	border: "#EAD7D1", // Un canela suave que define formas sin ser agresivo
	heading: "#4E342E", // Marrón más oscuro para que los títulos resalten
	muted: "#9E8279", // Para textos secundarios/deshabilitados
};
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link
			href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300;500;700&family=Soft+Cream&display=swap"
			rel="stylesheet"
		/>
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
	</head>
	<body
		class="bg-bg text-text flex flex-col items-center justify-center p-0 sm:p-8 transition-colors duration-500 font-quicksand min-h-screen"
	>
		<!-- Header Floating Button -->
		<div class="fixed top-12 left-12 lg:top-6 lg:left-8 z-50">
			<a href="/" class="flex items-center gap-3 group">
				<div
					class="w-10 h-10 bg-white border-2 border-border/40 rounded-xl flex items-center justify-center shadow-sm group-hover:border-primary/50 transition-all"
				>
					<span class="text-xl">✨</span>
				</div>
				<span
					class="text-lg font-black text-heading italic uppercase tracking-tighter opacity-0 group-hover:opacity-100 transition-opacity"
				>
					Layerly
				</span>
			</a>
		</div>

		<div
			class="fixed inset-0 pointer-events-none opacity-20 overflow-hidden"
		>
			<div
				class="absolute top-10 left-10 w-32 h-32 bg-primary blur-[100px]"
			>
			</div>
			<div
				class="absolute bottom-20 right-10 w-40 h-40 bg-secondary blur-[100px]"
			>
			</div>
		</div>
		<slot />
		<Footer />
		<div
			id="snackbar"
			class="fixed bottom-10 left-1/2 -translate-x-1/2 z-100 flex items-center gap-4 px-8 py-4 bg-white/90 border-4 border-border rounded-full shadow-[0_15px_40px_rgba(93,64,55,0.15)] backdrop-blur-md transition-all duration-700 ease-[cubic-bezier(0.175,0.885,0.32,1.275)] translate-y-28 opacity-0 pointer-events-none"
		>
			<div
				id="snackbar-icon"
				class="w-3 h-3 rounded-full shadow-inner ring-4 ring-white/50"
			>
			</div>

			<p
				id="snackbar-message"
				class="text-sm font-black text-heading italic tracking-tight"
			>
			</p>
		</div>
	</body>
</html>

<style
	is:global
	define:vars={{
		bg: Theme.bg,
		surface: Theme.surface,
		primary: Theme.primary,
		secondary: Theme.secondary,
		accent: Theme.accent,
		text: Theme.text,
		border: Theme.border,
		heading: Theme.heading,
		muted: Theme.muted,
	}}
>
	:root {
		--theme-bg: var(--bg);
		--theme-surface: var(--surface);
		--theme-primary: var(--primary);
		--theme-secondary: var(--secondary);
		--theme-accent: var(--accent);
		--theme-text: var(--text);
		--theme-border: var(--border);
		--theme-heading: var(--heading);
		--theme-muted: var(--muted);
	}

	body {
		background-image: radial-gradient(
			var(--theme-primary) 0.5px,
			transparent 0.5px
		);
		background-size: 24px 24px;
		background-color: var(--theme-bg);
		color: var(--theme-text);
		font-family: "Quicksand", sans-serif;
	}

	/* Efecto de bordes "suaves" para todo */
	* {
		cursor:
			url("https://cdn.cursors-4u.net/previews/pink-rose-flower-e61b4b6e-32.webp")
				32 32,
			auto !important;
	}
</style>

<script>
	const snackbar = document.getElementById("snackbar");
	const messageEl = document.getElementById("snackbar-message");
	const iconEl = document.getElementById("snackbar-icon");

	// Esta es la forma infalible:
	let timeout: ReturnType<typeof setTimeout> | undefined;

	window.showToast = (
		message: string,
		type: "error" | "success" | "info" = "info",
	) => {
		if (!snackbar || !messageEl || !iconEl) return;

		if (timeout) clearTimeout(timeout);

		// Colores Cottagecore para los estados
		const colors = {
			error: "bg-red-300 shadow-[0_0_15px_rgba(248,113,113,0.4)]",
			success: "bg-secondary shadow-[0_0_15px_rgba(168,213,186,0.4)]",
			info: "bg-primary shadow-[0_0_15px_rgba(255,181,194,0.4)]",
		};

		messageEl.textContent = message;
		iconEl.className = `w-3 h-3 rounded-full transition-all duration-500 ${colors[type]}`;

		// Mostrar con la nueva animación
		snackbar.classList.remove(
			"translate-y-28",
			"opacity-0",
			"pointer-events-none",
		);

		timeout = setTimeout(() => {
			snackbar.classList.add(
				"translate-y-28",
				"opacity-0",
				"pointer-events-none",
			);
		}, 4000);
	};

	document.addEventListener("DOMContentLoaded", () => {
		const urlParams = new URLSearchParams(window.location.search);
		const error = urlParams.get("error");
		const success = urlParams.get("success");

		const errorMessages: Record<string, string> = {
			not_found: "El proyecto no existe o fue eliminado.",
			unauthorized: "No tienes permiso para editar este proyecto.",
			db: "Error de conexión con la base de datos.",
			upload_fail: "No se pudo subir la imagen a Cloudinary.",
		};

		if (error && errorMessages[error]) {
			window.showToast(errorMessages[error], "error");

			// Limpiar la URL sin recargar la página
			const newUrl = window.location.pathname;
			window.history.replaceState({}, "", newUrl);
		}

		if (success) {
			window.showToast("¡Operación exitosa!", "success");
			window.history.replaceState({}, "", window.location.pathname);
		}
	});

	window.openModal = (id: string) => {
		const modal = document.getElementById(id);
		if (!modal) return;

		modal.classList.add("is-active");
		document.body.style.overflow = "hidden";
		// Aplicar desenfoque al contenedor principal si existe
		document.getElementById("main-wrapper")?.classList.add("modal-blur");
	};

	window.closeModal = (id: string) => {
		const modal = document.getElementById(id);
		if (!modal) return;

		modal.classList.remove("is-active");
		document.body.style.overflow = "";
		document.getElementById("main-wrapper")?.classList.remove("modal-blur");
	};

	// Listener universal para cerrar al hacer clic en el overlay (fuera del contenido)
	document.addEventListener("click", (e) => {
		const target = e.target as HTMLElement;
		if (
			target.classList.contains("modal-overlay") &&
			target.classList.contains("is-active")
		) {
			window.closeModal(target.id);
		}
	});

	// Cerrar con la tecla Escape
	document.addEventListener("keydown", (e) => {
		if (e.key === "Escape") {
			const activeModal = document.querySelector(
				".modal-overlay.is-active",
			);
			if (activeModal) window.closeModal(activeModal.id);
		}
	});
</script>
